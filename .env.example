# Copy this to .env on the server and fill in your own values.
# .env is gitignored and never pushed — each environment keeps its own.

# --- Required ---
DISCORD_TOKEN=your-bot-token-here

# --- Optional (defaults shown) ---
# Where data is stored INSIDE the container. Leave as-is; ./data on the host
# is mounted here by docker-compose, so the DB persists.
DB_FILE=data/foxhole.db

# Seconds between reminder ticks (stockpile/op/factory checks).
REMINDER_INTERVAL_SECONDS=60

# Log verbosity: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# How often to refresh the wiki item catalog / war number (hours).
CATALOG_SYNC_HOURS=48
WAR_SYNC_HOURS=24
